{
  "name": "@yawlabs/ctxlint",
  "version": "0.6.0",
  "description": "Lint your AI agent context files and MCP server configs against your actual codebase",
  "bin": {
    "ctxlint": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "mcp": "node dist/index.js --mcp-server"
  },
  "keywords": [
    "claude",
    "agents",
    "context",
    "lint",
    "linter",
    "claude-md",
    "agents-md",
    "ai-coding",
    "context-engineering",
    "mcp",
    "cursorrules",
    "copilot-instructions",
    "windsurfrules",
    "pre-commit",
    "agentic",
    "codex",
    "sarif",
    "mcp-server",
    "model-context-protocol",
    "context-lint",
    "gemini",
    "cline",
    "windsurf"
  ],
  "files": [
    "dist",
    ".pre-commit-hooks.yaml",
    "CONTEXT_LINT_SPEC.md",
    "MCP_CONFIG_LINT_SPEC.md",
    "context-lint-rules.json",
    "mcp-config-lint-rules.json",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YawLabs/ctxlint.git"
  },
  "bugs": {
    "url": "https://github.com/YawLabs/ctxlint/issues"
  },
  "homepage": "https://github.com/YawLabs/ctxlint",
  "author": "Yaw Labs <contact@yaw.sh>",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fast-levenshtein": "^3.0.0",
    "glob": "^13.0.6",
    "ora": "^9.3.0",
    "simple-git": "^3.33.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "tiktoken": "^1.0.22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/fast-levenshtein": "^0.0.4",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
