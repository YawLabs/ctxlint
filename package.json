{
  "name": "@yawlabs/ctxlint",
  "version": "0.2.0",
  "description": "Lint your AI agent context files (CLAUDE.md, AGENTS.md, etc.) against your actual codebase",
  "bin": {
    "ctxlint": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "mcp": "node dist/mcp/server.js"
  },
  "keywords": [
    "claude",
    "agents",
    "context",
    "lint",
    "claude-md",
    "agents-md",
    "ai-coding",
    "context-engineering",
    "mcp"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yawlabs/ctxlint.git"
  },
  "homepage": "https://github.com/yawlabs/ctxlint",
  "author": "Yaw Labs <contact@yaw.sh>",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fast-levenshtein": "^3.0.0",
    "glob": "^13.0.6",
    "ora": "^9.3.0",
    "simple-git": "^3.33.0",
    "tiktoken": "^1.0.22",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/fast-levenshtein": "^0.0.4",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
